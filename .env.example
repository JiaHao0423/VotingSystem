# 複製此檔為 .env 並填入實際值（本機 docker compose 用）
# ====== 資料庫 (Zeabur MySQL) ======
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=zeabur
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# ====== 預設超級管理員（首次啟動時建立）======
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ====== 對外服務（本機）======
FRONTEND_PORT=8080
VOTER_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ====== Zeabur GitHub 部署（在 Zeabur 後台設定環境變數）======
# 後端服務 Root Directory: backend
# SPRING_DATASOURCE_URL=jdbc:mysql://host:port/zeabur?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Taipei
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=change-me
# APP_VOTER_BASE_URL=https://你的前端網域
# APP_CORS_ALLOWED_ORIGINS=https://你的前端網域
#
# 前端服務 Root Directory: frontend
# BACKEND_URL=https://你的後端網域
